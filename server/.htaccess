RewriteEngine On
# 经 Rewrite 后 PHP 常读不到 Authorization；显式注入 HTTP_AUTHORIZATION 供 getAuthUser 使用
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^auth/(.*)$ api/auth/index.php?action=$1 [L,QSA]
RewriteRule ^payment/(.*)$ api/payment/index.php?action=$1 [L,QSA]
RewriteRule ^apikey/(.*)$ api/apikey/index.php?action=$1 [L,QSA]
