{
  "kiroAgent.configureMCP": "Disabled",
  "files.encoding": "utf8",
  "terminal.integrated.defaultProfile.windows": "PowerShell UTF-8",
  "terminal.integrated.profiles.windows": {
    "PowerShell UTF-8": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": [
        "-NoExit",
        "-Command",
        "chcp 65001 | Out-Null; [Console]::OutputEncoding = [System.Text.Encoding]::UTF8; [Console]::InputEncoding = [System.Text.Encoding]::UTF8; $OutputEncoding = [System.Text.Encoding]::UTF8"
      ]
    },
    "CMD UTF-8": {
      "path": "${env:windir}\\System32\\cmd.exe",
      "args": ["/K", "chcp 65001"],
      "icon": "terminal-cmd"
    }
  }
}
